"use client";

import { Search } from "lucide-react";
import { useRouter } from "next/navigation";
import {
  useState,
  ChangeEvent,
  FormEvent,
} from "react";

type SearchBoxProps = {
  value?: string;
  onChange?: (value: string) => void;
  placeholder?: string;
  redirectToSearch?: boolean;
};

export default function SearchBox({
  value,
  onChange,
  placeholder = "Cari berita, pakar, agenda...",
  redirectToSearch = false,
}: SearchBoxProps) {
  const router = useRouter();

  const [internalValue, setInternalValue] =
    useState("");

  // SAFE VALUE
  const inputValue =
    typeof value === "string"
      ? value
      : internalValue;

  /* =========================
     CHANGE
  ========================= */
  function handleChange(
    e: ChangeEvent<HTMLInputElement>
  ) {
    const newValue = e.target.value;

    // INTERNAL STATE
    if (value === undefined) {
      setInternalValue(newValue);
    }

    // SAFE CALLBACK
    if (
      onChange &&
      typeof onChange === "function"
    ) {
      onChange(newValue);
    }
  }

  /* =========================
     SUBMIT
  ========================= */
  function handleSubmit(
    e: FormEvent<HTMLFormElement>
  ) {
    e.preventDefault();

    if (!redirectToSearch) return;

    const keyword =
      inputValue.trim();

    if (!keyword) return;

    router.push(
      `/search?q=${encodeURIComponent(
        keyword
      )}`
    );
  }

  return (
    <form
      onSubmit={handleSubmit}
      className="relative w-full"
    >

      {/* ICON */}
      <div className="pointer-events-none absolute left-4 top-1/2 z-10 -translate-y-1/2">
        <Search className="h-5 w-5 text-gray-400" />
      </div>

      {/* INPUT */}
      <input
        type="text"
        value={inputValue}
        onChange={handleChange}
        placeholder={placeholder}
        className="
          h-14
          w-full
          rounded-2xl
          border
          border-gray-200
          bg-white
          pl-12
          pr-24
          text-sm
          text-gray-800
          shadow-sm
          outline-none
          transition-all
          placeholder:text-gray-400
          focus:border-green-600
          focus:ring-4
          focus:ring-green-100
        "
      />

      {/* BUTTON */}
      {redirectToSearch && (
        <button
          type="submit"
          className="
            absolute
            right-2
            top-1/2
            -translate-y-1/2
            rounded-xl
            bg-green-700
            px-4
            py-2
            text-xs
            font-semibold
            text-white
            transition
            hover:bg-green-800
          "
        >
          Cari
        </button>
      )}

    </form>
  );
}