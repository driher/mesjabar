"use client";

import { useEffect, useState } from "react";

export default function KursIDRTable() {
  const [data, setData] = useState<any>(null);
  const [prev, setPrev] = useState<any>(null);

  const fetchData = async () => {
    const res = await fetch("/api/kurs");
    const json = await res.json();

    setPrev(data);
    setData(json);
  };

  useEffect(() => {
    fetchData();
    const interval = setInterval(fetchData, 60000);
    return () => clearInterval(interval);
  }, []);

  const renderRow = (label: string, key: string) => {
    const value = data?.[key];
    const old = prev?.[key];

    const up = old && value > old;

    return (
      <tr key={key} className="border-b">
        <td className="py-2 font-medium">{label}</td>
        <td
          className={`py-2 transition-all duration-300 ${
            up ? "text-green-600 scale-105" : "text-red-600"
          }`}
        >
          Rp {value ? value.toLocaleString("id-ID") : "-"}
        </td>
      </tr>
    );
  };

  return (
    <div className="bg-white p-5 rounded-2xl shadow-md w-full max-w-lg">

      {/* TITLE */}
      <h2 className="text-lg font-bold mb-3">
        Kurs Rupiah terhadap Mata Uang
      </h2>

      {/* TABLE */}
      <table className="w-full text-sm">
        <tbody>
          {data && renderRow("Dolar AS (USD)", "USD")}
          {data && renderRow("Euro (EUR)", "EUR")}
          {data && renderRow("Riyal Saudi (SAR)", "SAR")}
          {data && renderRow("Yen Jepang (JPY)", "JPY")}
          {data && renderRow("Dolar Australia (AUD)", "AUD")}
        </tbody>
      </table>

      {/* SOURCE */}
      <p className="text-[10px] text-gray-400 mt-3">
        Sumber: Exchange Rate API (data referensi pasar forex global)
      </p>

    </div>
  );
}