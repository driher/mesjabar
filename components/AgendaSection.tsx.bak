"use client";

import { useEffect, useState } from "react";

type Agenda = {
  title: string;
  day: string;
  month: string;
  time: string;
  location: string;
};

export default function AgendaSection() {
  const [agenda, setAgenda] = useState<Agenda[]>([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    const controller = new AbortController();

    const fetchAgenda = async () => {
      try {
        const res = await fetch(
          "https://mada.akarmusic.com/wp-json/wp/v2/agenda",
          {
            signal: controller.signal,
            cache: "no-store",
          }
        );

        if (!res.ok) {
          throw new Error("Fetch gagal");
        }

        const data = await res.json();

        const formatted = data.map((item: any) => {
          const rawDate = item?.acf?.tanggal || "";

          let day = "--";
          let month = "---";

          if (rawDate.includes("/")) {
            const parts = rawDate.split("/");

            day = parts[0];

            const monthNumber = parseInt(parts[1]);

            const months = [
              "JAN",
              "FEB",
              "MAR",
              "APR",
              "MEI",
              "JUN",
              "JUL",
              "AGU",
              "SEP",
              "OKT",
              "NOV",
              "DES",
            ];

            month = months[monthNumber - 1];
          }

          return {
            title: item?.title?.rendered || "Tanpa Judul",
            day,
            month,
            time: item?.acf?.jam || "-",
            location: item?.acf?.lokasi || "-",
          };
        });

        setAgenda(formatted);
      } catch (err) {
        console.error(err);

        setAgenda([]);
      } finally {
        setLoading(false);
      }
    };

    fetchAgenda();

    return () => controller.abort();
  }, []);

  return (
    <section>
      <div className="mb-5 flex items-center justify-between">
        <h2 className="text-2xl font-black text-slate-900">
          Agenda
        </h2>

        <button className="rounded-xl border border-gray-200 bg-white px-3 py-2 text-xs font-semibold shadow-sm">
          Semua Agenda
        </button>
      </div>

      {loading && (
        <div className="rounded-2xl bg-white p-5 text-sm text-gray-500 shadow-sm">
          Loading agenda...
        </div>
      )}

      {!loading && agenda.length === 0 && (
        <div className="rounded-2xl bg-white p-5 text-sm text-gray-500 shadow-sm">
          Agenda tidak tersedia
        </div>
      )}

      <div className="space-y-4">
        {agenda.map((item, index) => (
          <div
            key={index}
            className="rounded-2xl border border-green-100 bg-white p-4 shadow-sm"
          >
            <div className="flex gap-4">
              <div className="flex h-16 w-16 shrink-0 flex-col items-center justify-center rounded-2xl bg-green-600 text-white">
                <span className="text-2xl font-black">
                  {item.day}
                </span>

                <span className="text-[10px] font-bold">
                  {item.month}
                </span>
              </div>

              <div className="flex-1">
                <h3
                  className="text-sm font-bold leading-snug text-slate-800"
                  dangerouslySetInnerHTML={{
                    __html: item.title,
                  }}
                />

                <div className="mt-3 space-y-1">
                  <p className="text-xs text-slate-500">
                    🕒 {item.time}
                  </p>

                  <p className="text-xs text-slate-500">
                    📍 {item.location}
                  </p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>
  );
}