                  <div className="p-5">

                    <span className="text-xs font-semibold uppercase tracking-wide text-orange-500">
                      {item.category}
                    </span>

                    <h2 className="mt-2 line-clamp-3 text-lg font-bold leading-7 text-gray-900">
                      {item.title}
                    </h2>

