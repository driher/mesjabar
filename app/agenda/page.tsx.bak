                    />

                  </div>

                  <div className="p-3">

                    <h3 className="line-clamp-3 text-sm font-bold leading-5 text-gray-800">
                      {item.title}
                    </h3>

                  </div>

                </Link>
              ))}

            </div>

            {/* ================================= GRID NEWS ================================= */}
            <div className="mt-8 grid grid-cols-1 gap-5 md:grid-cols-3">

              {latestNews.map((item) => (
                <Link
