export async function GET() {
  try {
    const res = await fetch(
      "https://mada.akarmusic.com/wp-json/wp/v2/pakar?per_page=100&_embed",
      {
        cache: "no-store",
      }
    );

    if (!res.ok) {
      throw new Error("Failed to fetch");
    }

    const data = await res.json();

    const clean = data.map((item: any) => ({
      id: item.id,
      slug: item.slug,
      name: item.title?.rendered || "Tanpa Nama",
      link: `/pakar/${item.slug}`, // ✅ IMPORTANT FIX
      bidang: item?.custom_fields?.bidang || "",
      foto:
        item?._embedded?.["wp:featuredmedia"]?.[0]?.source_url || null,
    }));

    return Response.json(clean);
  } catch (e) {
    return Response.json(
      { error: "failed to fetch pakar" },
      { status: 500 }
    );
  }
}