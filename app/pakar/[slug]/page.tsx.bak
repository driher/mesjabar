```tsx
import { notFound } from "next/navigation";

interface PageProps {
  params: Promise<{
    slug: string;
  }>;
}

async function getPakarBySlug(slug: string) {
  const res = await fetch(
    `https://cms.ekonomisyariahjabar.id/wp-json/wp/v2/pakar?slug=${slug}&_embed`,
    {
      cache: "no-store",
    }
  );

  if (!res.ok) return null;

  const data = await res.json();

  return data?.[0] || null;
}

export default async function DetailPakar({
  params,
}: PageProps) {
  const { slug } = await params;

  const data = await getPakarBySlug(slug);

  if (!data) {
    notFound();
  }

  const custom = data?.custom_fields || {};

  const nama =
    data?.title?.rendered ||
    "Tanpa Nama";

  const wpImage =
    data?._embedded?.["wp:featuredmedia"]?.[0]
      ?.source_url;

  const avatar = `https://ui-avatars.com/api/?name=${encodeURIComponent(
    nama
  )}&background=15803d&color=fff&size=400`;

  const foto =
    custom?.foto &&
    typeof custom.foto === "string" &&
    custom.foto.startsWith("http")
      ? custom.foto
      : wpImage || avatar;

  return (
    <div className="min-h-screen bg-gray-50 py-10">
      <div className="max-w-6xl mx-auto px-4">

        <div className="bg-white rounded-3xl overflow-hidden shadow-xl border">

          {/* HEADER */}
          <div className="h-64 bg-gradient-to-r from-green-900 via-green-700 to-emerald-500" />

          {/* CONTENT */}
          <div className="relative px-8 pb-10">

            {/* FOTO */}
            <div className="absolute -top-24 left-8">
              <img
                src={foto}
                alt={nama}
                className="w-44 h-44 rounded-full border-8 border-white object-cover shadow-xl"
              />
            </div>

            <div className="pt-28">

              <span className="inline-flex rounded-full bg-green-100 px-4 py-2 text-sm font-medium text-green-700">
                Pakar MES Jawa Barat
              </span>

              <h1
                className="mt-5 text-4xl font-bold text-gray-900"
                dangerouslySetInnerHTML={{
                  __html: nama,
                }}
              />

              <p className="mt-3 text-lg text-gray-600">
                {custom?.domisili ||
                  "Domisili belum tersedia"}
              </p>

              <div className="grid gap-8 mt-10 lg:grid-cols-3">

                {/* KONTEN */}
                <div className="lg:col-span-2 space-y-6">

                  {/* BIDANG KEAHLIAN */}
                  <div className="bg-gray-50 border rounded-2xl p-6">

                    <h2 className="text-2xl font-bold mb-4">
                      Bidang Keahlian
                    </h2>

                    <div
                      className="prose max-w-none"
                      dangerouslySetInnerHTML={{
                        __html:
                          custom?.bidang_keahlian ||
                          "<p>Belum tersedia.</p>",
                      }}
                    />
                  </div>

                  {/* REKAM JEJAK */}
                  <div className="bg-gray-50 border rounded-2xl p-6">

                    <h2 className="text-2xl font-bold mb-4">
                      Rekam Jejak Akademik dan Profesional
                    </h2>

                    <div
                      className="prose max-w-none"
                      dangerouslySetInnerHTML={{
                        __html:
                          custom?.rekam_jejak_akademik_dan_profesional ||
                          "<p>Belum tersedia.</p>",
                      }}
                    />
                  </div>

                  {/* BIO KONTEN WORDPRESS */}
                  {data?.content?.rendered && (
                    <div className="bg-gray-50 border rounded-2xl p-6">

                      <h2 className="text-2xl font-bold mb-4">
                        Profil Lengkap
                      </h2>

                      <div
                        className="prose max-w-none"
                        dangerouslySetInnerHTML={{
                          __html:
                            data.content.rendered,
                        }}
                      />
                    </div>
                  )}
                </div>

                {/* SIDEBAR */}
                <div className="bg-gray-50 border rounded-2xl p-6 h-fit sticky top-5">

                  <h2 className="text-2xl font-bold mb-5">
                    Kontak & Media Sosial
                  </h2>

                  <div className="space-y-4">

                    <div>
                      <div className="font-semibold">
                        Domisili
                      </div>
                      <div>
                        {custom?.domisili || "-"}
                      </div>
                    </div>

                    <div>
                      <div className="font-semibold">
                        Email
                      </div>
                      <div>
                        {custom?.email ? (
                          <a
                            href={`mailto:${custom.email}`}
                            className="text-green-700 hover:underline"
                          >
                            {custom.email}
                          </a>
                        ) : (
                          "-"
                        )}
                      </div>
                    </div>

                    {custom?.linkedin && (
                      <div>
                        <div className="font-semibold">
                          LinkedIn
                        </div>
                        <a
                          href={custom.linkedin}
                          target="_blank"
                          rel="noopener noreferrer"
                          className="text-green-700 hover:underline"
                        >
                          Lihat Profil
                        </a>
                      </div>
                    )}

                    {custom?.x && (
                      <div>
                        <div className="font-semibold">
                          X
                        </div>
                        <a
                          href={custom.x}
                          target="_blank"
                          rel="noopener noreferrer"
                          className="text-green-700 hover:underline"
                        >
                          Kunjungi
                        </a>
                      </div>
                    )}

                    {custom?.instagram && (
                      <div>
                        <div className="font-semibold">
                          Instagram
                        </div>
                        <a
                          href={custom.instagram}
                          target="_blank"
                          rel="noopener noreferrer"
                          className="text-green-700 hover:underline"
                        >
                          Kunjungi
                        </a>
                      </div>
                    )}

                    {custom?.facebook && (
                      <div>
                        <div className="font-semibold">
                          Facebook
                        </div>
                        <a
                          href={custom.facebook}
                          target="_blank"
                          rel="noopener noreferrer"
                          className="text-green-700 hover:underline"
                        >
                          Kunjungi
                        </a>
                      </div>
                    )}

                    {custom?.youtube && (
                      <div>
                        <div className="font-semibold">
                          YouTube
                        </div>
                        <a
                          href={custom.youtube}
                          target="_blank"
                          rel="noopener noreferrer"
                          className="text-green-700 hover:underline"
                        >
                          Kunjungi Channel
                        </a>
                      </div>
                    )}

                    <hr />

                    <div className="text-sm text-gray-500">
                      <div>ID: #{data.id}</div>
                      <div>Slug: {data.slug}</div>
                    </div>

                  </div>

                </div>

              </div>

            </div>

          </div>

        </div>

      </div>
    </div>
  );
}
```
